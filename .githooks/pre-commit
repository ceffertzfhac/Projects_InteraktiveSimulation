#!/usr/bin/env bash
# Verhindert, dass unerwünschte Dateien committed werden.

blocked=()

while IFS= read -r file; do
  blocked+=("$file")
done < <(git diff --cached --name-status | grep -E '^(A|M)\s' | awk '{print $2}' | grep -E '(\.DS_Store|/test\.txt|^test\.txt|\.AppleDouble)$')

if [ ${#blocked[@]} -gt 0 ]; then
  echo ""
  echo "FEHLER: Folgende Dateien gehören nicht ins Repository:"
  for f in "${blocked[@]}"; do
    echo "   $f"
  done
  echo ""
  echo "  Entfernen mit: git restore --staged <datei>"
  echo ""
  exit 1
fi

# ── Webpage-Deploy-Sync-Guard (BACKLOG I11) ────────────────────────────────────
# Regel: nach Änderungen an Project_*/ oder shared/ muss Webpage/ synchron sein,
# sonst driftet die öffentliche Pages-Site. Nur prüfen, wenn der Commit solche
# Pfade berührt — reine Docs-/Skill-/Scaffold-Commits deployen ohnehin nicht und
# bleiben ungebremst. Notfall-Umgehung: git commit --no-verify.
if git diff --cached --name-only \
     | grep -qE '^(Project_.*_simulation/(js/|css/|index\.html)|shared/|Webpage/)'; then
  drift_script="scripts/check-webpage-drift.sh"
  if [ -f "$drift_script" ]; then
    drift_out="$(bash "$drift_script" 2>&1)"; drift_rc=$?
    if [ $drift_rc -ne 0 ]; then
      echo ""
      echo "FEHLER: Webpage/ ist nicht synchron mit Project_*/shared/ (I11)."
      echo "  → 'bash scripts/sync-webpage.sh' ausführen, dann erneut committen."
      echo ""
      printf '%s\n' "$drift_out" | sed 's/^/  /'
      echo ""
      exit 1
    fi
  fi
fi

exit 0
